# NewtNode
# Copy this file to .env, then replace the placeholder values with your own keys.

# Required for fal.ai video generation, utility models, and OpenAI Image 2 through fal.
FAL_KEY=your_fal_key_here

# Required for the Nano Banana Pro image model.
GOOGLE_API_KEY=your_google_api_key_here

# Local server port.
PORT=3333

# Optional: OpenAI Image 2 quality when routed through fal.
# FAL_OPENAI_IMAGE_2_QUALITY=medium

# Optional: cost estimate overrides for the Stats tab.
# SEEDANCE_STANDARD_COST_PER_SECOND=0.3034
# SEEDANCE_FAST_COST_PER_SECOND=0.2419
# NANO_BANANA_IMAGE_COST_1K_2K=0.15
# NANO_BANANA_IMAGE_COST_4K=0.30
# OPENAI_IMAGE_2_MEDIUM_COST=0.053
